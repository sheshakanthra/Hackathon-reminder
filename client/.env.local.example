# ─────────────────────────────────────────────────────────────
#  HackReminder — Environment Variables
#  Copy this file to .env.local and fill in your keys.
#  Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Stage 1: Groq AI URL Extraction ───────────────────────────
# Free key at https://console.groq.com
VITE_GROQ_API_KEY=gsk_...

# ── Stage 3: Resend Email Reminders ───────────────────────────
# Free key at https://resend.com  (100 emails/day, 3000/month)
VITE_RESEND_API_KEY=re_...

# "from" address — leave blank to use onboarding@resend.dev (free tier, no domain needed).
# Once you verify your own domain on resend.com, set this to:
#   Your Name <you@yourdomain.com>
VITE_RESEND_FROM=

# ── Stage 4 (future): Google Calendar OAuth ───────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=....apps.googleusercontent.com
VITE_GOOGLE_API_KEY=AIza...

# ── Backend API (leave as-is while offline) ───────────────────
VITE_API_URL=https://hackathon-reminder.onrender.com/api
